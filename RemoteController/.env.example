# Required — fail fast on boot if missing
KNOVAS_INTERNAL_API_URL=http://internal-api:5000
RC_INSTANCE_TOKEN=change-me-from-knovas-admin
RC_CLIENT_ID=00000000-0000-0000-0000-000000000001
RC_WATCH_ROOTS=/data/docs,/data/contracts
SEMANTIX_SECURE_BASE_URL=https://nginx:8443
SEMANTIX_CLIENT_CERT_PATH=/certs/tenant-client.pem
SEMANTIX_CLIENT_KEY_PATH=/certs/tenant-client.key
SEMANTIX_CA_CERT_PATH=/certs/ca.pem

# API
RC_API_PORT=5001

# GI-RC-02 rate limits
RC_RATE_LIMIT_ENABLED=true
RC_RATE_LIMIT_IP_MAX_TOKENS=30
RC_RATE_LIMIT_IP_REFILL_PER_SEC=0.5
RC_RATE_LIMIT_HANDLED_MAX_TOKENS=10
RC_RATE_LIMIT_HANDLED_REFILL_PER_SEC=0.2

# Knovas verify
KNOVAS_VERIFY_CACHE_TTL_SECONDS=45
RC_VERIFY_TIMEOUT_SECONDS=10

# Dev/test only — never enable in production
# RC_SKIP_CONFIG_VALIDATION=true  # skips required-env check at boot (pytest only)

# Sync scheduler
RC_SYNC_CONFIG_PATH=config/remote_controller_sync.json
RC_SYNC_CONFIG_API_ENABLED=false
RC_SYNC_AUTO_START_CONTINUOUS=false
RC_SYNC_AUTO_START_REQUIRES_SAVED_BODY=true
RC_TIMEZONE=
RC_SYNC_STATE_PATH=.rc-sync-state.json
RC_SYNC_DEFAULT_MODE=continuous
RC_SYNC_DEFAULT_WINDOW_START=08:00
RC_SYNC_DEFAULT_WINDOW_END=20:00
RC_SYNC_DEFAULT_MAX_INGESTION_REQUESTS_PER_MINUTE=30
RC_SYNC_DEFAULT_BURST=5
RC_SYNC_DEFAULT_SCAN_INTERVAL_SECONDS=60
