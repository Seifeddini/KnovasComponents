{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "scheduler_status",
    "files_scanned",
    "files_uploaded",
    "files_skipped",
    "ingestion_requests_sent",
    "transmissions",
    "errors"
  ],
  "additionalProperties": false,
  "properties": {
    "status": { "type": "string" },
    "scheduler_status": { "type": "string" },
    "files_scanned": { "type": "integer", "minimum": 0 },
    "files_uploaded": { "type": "integer", "minimum": 0 },
    "files_skipped": { "type": "integer", "minimum": 0 },
    "ingestion_requests_sent": { "type": "integer", "minimum": 0 },
    "paused_reason": { "type": ["string", "null"] },
    "transmissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "status"],
        "additionalProperties": true,
        "properties": {
          "path": { "type": "string" },
          "transmission_key_id": { "type": "string" },
          "parts": { "type": "integer", "minimum": 0 },
          "status": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "error"],
        "properties": {
          "path": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    "transmissions_truncated": { "type": "boolean" },
    "document_sync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "synced": { "type": "integer", "minimum": 0 },
        "pending": { "type": "integer", "minimum": 0 },
        "modified": { "type": "integer", "minimum": 0 },
        "excluded_max_age": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
