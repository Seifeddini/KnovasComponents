{
  "mode": "incremental",
  "sources": [{ "path": "/data/docs", "recursive": true }],
  "filters": {
    "include_globs": ["**/*.md", "**/*.txt"],
    "exclude_globs": ["**/.git/**"],
    "max_document_age_seconds": 2592000
  },
  "ingestion": {
    "identifier_prefix": "rc-sync",
    "part_max_chars": 50000
  }
}
