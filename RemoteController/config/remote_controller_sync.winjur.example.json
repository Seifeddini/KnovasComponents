{
  "schema_version": 1,
  "enabled": true,
  "mode": "continuous",
  "window": {
    "start_local": "00:00",
    "end_local": "23:59"
  },
  "rate_limit": {
    "max_ingestion_requests_per_minute": 4,
    "burst": 1
  },
  "pause_policy": "finish_current_unit_then_pause",
  "scan_interval_seconds": 120,
  "scan_interval_idle_max_seconds": 3600,
  "max_files_per_cycle": 200,
  "max_scan_entries_per_cycle": 10000,
  "max_sync_duration_minutes": 120,
  "sequential_subfolders": true
}
