# -----------------------------------------------------------------------------
# Knovas Platform Configuration
# -----------------------------------------------------------------------------
# Copy to .env and adjust values.

# Runtime
ENVIRONMENT=local

# Web app
DOCBRIDGE_WEB_PORT=8081
WEB_SECRET_KEY=replace-with-random-hex
COMPANY_LOGIN_ENABLED=true
COMPANY_DISPLAY_NAME=Knovas
COMPANY_LOGIN_NAME=company
COMPANY_LOGIN_PASSWORD=replace-with-strong-company-password
DOCBRIDGE_WEB_WORKERS=2
DOCBRIDGE_WEB_THREADS=4
DOCBRIDGE_WEB_TIMEOUT=120
LOG_LEVEL=INFO

# File open on the user's PC via browser (no extra install) — see docs/integration/opening-documents.md
OPEN_BROWSER_CLIENT_PATH=true
OPEN_COMPANION_ENABLED=false
OPEN_TOKEN_TTL_SECONDS=120
OPEN_PUBLIC_BASE_URL=
# How Windows clients see the share (e.g. \\fileserver\AutoDocShare)
OPEN_UNC_ROOT=
OPEN_LOCAL_ROOT=/mnt/autodoc
# How Linux clients mount the same share (e.g. /mnt/autodoc)
OPEN_CLIENT_LOCAL_ROOT=
OPEN_PDF_INLINE_IN_BROWSER=true
OPEN_ALLOW_SERVER_SIDE_STARTFILE=false
OPEN_ALLOW_DEGRADED_DOWNLOAD_OPEN=false

# Knovas API
# Default: secured Knovas API via mTLS.
# For offline mock mode set:
#   SEMANTIX_API_URL=http://semantix-mock:5000
#   SEMANTIX_USE_SECURED_API=false
#   SEMANTIX_ALLOW_LEGACY_API_FALLBACK=true
SEMANTIX_API_URL=https://host.docker.internal:8443
SEMANTIX_USE_SECURED_API=true
SEMANTIX_ALLOW_LEGACY_API_FALLBACK=false
SEMANTIX_API_KEY=
SEMANTIX_QUERY_ENDPOINT=/secured/query
SEMANTIX_HEALTH_ENDPOINT=/secured/health
SEMANTIX_SEARCH_ENDPOINT=/api/search
DOCBRIDGE_WEB_IMAGE=docbridge-web-clientbundle:latest

# Document file-open (web app: AutoDoc mount for direct file access)
AUTODOC_MOUNT_PATH=/mnt/docbridge_share/AutoDoc

# Knovas mTLS certificates (mount directory into containers)
SEMANTIX_CERTS_DIR=./certs
SEMANTIX_CLIENT_CERT=/app/certs/client.crt
SEMANTIX_CLIENT_KEY=/app/certs/client.key
SEMANTIX_CA_CERT=/app/certs/ca.crt
# Optional: explicit tenant UUID for automatic certificate renewal.
# If omitted, the service tries to resolve it from certificate subject CN/OU.
SEMANTIX_CUSTOMER_ID=
# Automatic renewal controls (self-service via POST /secured/generate_certificate).
SEMANTIX_CERT_AUTO_RENEW_ENABLED=true
SEMANTIX_CERT_RENEW_THRESHOLD_DAYS=30
SEMANTIX_CERT_CHECK_INTERVAL_SECONDS=3600
# Optional: path inside container to encryption matrix JSON (encrypted-embedding tenants)
SEMANTIX_ENCRYPTION_MATRIX_PATH=
